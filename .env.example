# Copy to .env and fill in values. Never commit .env.
# Optional: copy .openclaude-profile.example.json → .openclaude-profile.json (gitignored) for local AI tooling — never commit real keys.

PORT=3000
NODE_ENV=development

# Required in production (>=32 chars each). In development, API_KEY_HASH_SECRET falls back to a dev default if unset.
REDIS_URL=
API_KEY_HASH_SECRET=
# In development/test, if unset, a built-in dev fallback is used for /portal sandbox proxy and MCP call_tool (set a real >=32 char secret for production).
INTERNAL_SECRET=

# Optional: Swagger / docs sandbox key (>=16 chars if set). Tier: free | mercury | venus | saturn (default mercury). Never use admin here.
SWAGGER_SANDBOX_API_KEY=
SWAGGER_SANDBOX_TIER=mercury

# Set to 1 to accept literal dev_test_key (admin tier) even when NODE_ENV=production — avoid in public production.
ALLOW_LEGACY_DEV_TEST_KEY=

# Cron / internal refresh — required for POST /api/v1/internal/horoscope-refresh to succeed
INTERNAL_CRON_TOKEN=

# Optional: protect GET /metrics in production (Bearer or X-Metrics-Token). If unset, /metrics stays public.
METRICS_BEARER_TOKEN=

# Swiss Ephemeris optional file path (packaged ephemeris used if unset)
SWEPH_EPHE_PATH=

# Optional: system Chromium for PDFs in Docker/Linux (see Dockerfile)
PUPPETEER_EXECUTABLE_PATH=

# Optional bootstrap keys JSON: [{"key":"...","tier":"mercury","status":"active"}]
API_KEYS_JSON=
